    {
      "clause": {
        "id": "c008",
        "text": "1.\nRecipient acknowledges that a Board members fiduciary duty includes the obligation to not disclose and to maintain the\nconfidentiality of all information disclosed by the Company to Recipient in connection with Recipients status as a Board\nmember, whether in oral, written, graphic, or electronic form (subject to the limitations set forth in Section 3, referred to herein\nas the \nConfidential Information\n). The Confidential Information will be shared by the Company with the Board in\norder to permit the Board to carry out its responsibilities.",
        "start_char": 1275,
        "end_char": 1829
      },
      "classification": {
        "label": "Confidentiality",
        "confidence": 0.62,
        "rationale_short": "keyword baseline"
      },
      "flags": [],
      "analysis": {
